generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  clerkId            String    @unique
  email              String    @unique
  name               String?
  subscriptionStatus String    @default("inactive")
  stripeCustomerId   String?   @unique
  stripeSubId        String?   @unique
  currentPeriodEnd   DateTime?
  geminiApiKey       String?   @db.Text
  openaiApiKey       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  analyses           Analysis[]
  trades             Trade[]
  watchlist          Watchlist[]
  signals            Signal[]
  ticks              MarketTick[]
}

model Analysis {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode          String
  imageUrl      String?  @db.Text
  status        String
  asset         String?
  timeframe     String?
  resultJson    Json
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId  String?
  signalId    String?   @unique

  asset       String
  timeframe   String?
  mode        String
  direction   String

  entryPrice  Float
  stopPrice   Float
  targetPrice Float?

  exitPrice   Float?
  outcome     String    @default("OPEN")
  pnlAmount   Float?
  rMultiple   Float?

  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?   @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, openedAt])
  @@index([userId, mode, outcome])
}

model Watchlist {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String
  timeframe   String   @default("M15")
  mode        String   // "SMC" | "CLASSICO"
  active      Boolean  @default(true)
  lastScanAt  DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, symbol, timeframe, mode])
  @@index([userId, active])
}

model Signal {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  symbol            String
  timeframe         String
  mode              String

  hasSetup          Boolean  @default(true)
  direction         String?
  probability       Int?
  confidence        String?

  entryPrice        Float?
  entryZoneLow      Float?
  entryZoneHigh     Float?
  stopPrice         Float?
  target1           Float?
  target2           Float?
  target3           Float?
  recommendedTarget Int?
  riskReward        String?

  structure         String?  @db.Text
  justification     String?  @db.Text

  tipoSetup         String?
  checklistSmc      Json?
  checklistClassico Json?

  status            String   @default("PENDING") // PENDING | FILLED | WIN | LOSS | EXPIRED | NO_SETUP
  filledAt          DateTime?
  closedAt          DateTime?
  exitPrice         Float?
  rMultiple         Float?

  tradeCreated      Boolean  @default(false)

  scannedAt         DateTime @default(now())
  candleData        Json?

  @@index([userId, scannedAt])
  @@index([userId, status])
  @@index([userId, symbol, timeframe])
}

model MarketTick {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  bid       Float
  ask       Float
  spread    Float
  updatedAt DateTime @default(now())

  @@id([userId, symbol])
}
