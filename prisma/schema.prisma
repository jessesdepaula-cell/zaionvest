generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  clerkId            String    @unique
  email              String    @unique
  name               String?
  subscriptionStatus String    @default("inactive")
  stripeCustomerId   String?   @unique
  stripeSubId        String?   @unique
  currentPeriodEnd   DateTime?
  geminiApiKey       String?   @db.Text
  openaiApiKey       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  analyses           Analysis[]
  trades             Trade[]
  watchlist          Watchlist[]
  signals            Signal[]
  ticks              MarketTick[]
  eaDownloads        EADownload[]
}

model Analysis {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode          String
  imageUrl      String?  @db.Text
  status        String
  asset         String?
  timeframe     String?
  resultJson    Json
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId  String?
  signalId    String?   @unique

  asset       String
  timeframe   String?
  mode        String
  direction   String

  entryPrice  Float
  stopPrice   Float
  targetPrice Float?

  exitPrice   Float?
  outcome     String    @default("OPEN")
  pnlAmount   Float?
  rMultiple   Float?

  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?   @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, openedAt])
  @@index([userId, mode, outcome])
}

model Watchlist {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String
  timeframe   String   @default("M15")
  mode        String   // "SMC" | "CLASSICO"
  active      Boolean  @default(true)
  lastScanAt  DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, symbol, timeframe, mode])
  @@index([userId, active])
}

model Signal {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  symbol            String
  timeframe         String
  mode              String

  hasSetup          Boolean  @default(true)
  direction         String?
  probability       Int?
  confidence        String?

  entryPrice        Float?
  entryZoneLow      Float?
  entryZoneHigh     Float?
  stopPrice         Float?
  target1           Float?
  target2           Float?
  target3           Float?
  recommendedTarget Int?
  riskReward        String?

  structure         String?  @db.Text
  justification     String?  @db.Text

  tipoSetup         String?
  checklistSmc      Json?
  checklistClassico Json?

  status            String   @default("PENDING") // PENDING | FILLED | WIN | LOSS | EXPIRED | NO_SETUP
  filledAt          DateTime?
  closedAt          DateTime?
  exitPrice         Float?
  rMultiple         Float?
  maxTargetHit      Int?     // maior alvo atingido: 1, 2 ou 3 (null = nenhum)

  tradeCreated      Boolean  @default(false)

  scannedAt         DateTime @default(now())
  candleData        Json?

  @@index([userId, scannedAt])
  @@index([userId, status])
  @@index([userId, symbol, timeframe])
}

model MarketTick {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  bid       Float
  ask       Float
  spread    Float
  updatedAt DateTime @default(now())

  @@id([userId, symbol])
}

// ─── EA Marketplace ──────────────────────────────────────────────────────────

model EA {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  symbol          String
  timeframe       String
  style           String   // "trend" | "reversal" | "breakout" | "range"
  exitMode        String   // "reversal" | "fixed_sltp"

  // Métricas WFA (pipeline DQ Labs)
  wfe             Float?
  profitFactor    Float?
  maxDrawdown     Float?
  totalTrades     Int?
  oosWins         Int?
  oosTotalWindows Int?

  // Status de aprovação
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  lastValidatedAt DateTime?

  // Caminho do .ex5 compilado no storage (Modelo A: params baked-in no binário)
  fileUrl         String?  @db.Text

  // Curva de capital OOS (array de {date, value})
  equityCurveOos  Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  downloads       EADownload[]
  validations     EAValidation[]
  jobs            Job[]

  @@index([status])
  @@index([symbol, timeframe])
}

model EADownload {
  id        String   @id @default(cuid())
  eaId      String
  ea        EA       @relation(fields: [eaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eaId, userId])
  @@index([userId])
  @@index([eaId])
}

model EAValidation {
  id            String   @id @default(cuid())
  eaId          String
  ea            EA       @relation(fields: [eaId], references: [id], onDelete: Cascade)

  // Resultado consolidado da revalidação
  wfe           Float
  oosWins       Int
  oosTotalWin   Int
  approved      Boolean
  reportMd      String?  @db.Text

  // Janelas individuais da WFA (JSON array)
  windowsJson   Json?

  validatedAt   DateTime @default(now())

  @@index([eaId, validatedAt])
}

// ─── Fila de jobs (consumida pelo worker Windows/MT5) ────────────────────────
// A Vercel só ENFILEIRA (mineração/revalidação). O trabalho pesado — backtest
// no MT5, WFA, Monte Carlo, compilação do .ex5 — roda no worker, que reclama
// jobs PENDING, executa e devolve o resultado.

model Job {
  id          String   @id @default(cuid())
  type        String   // "REVALIDATE" | "MINE"
  status      String   @default("PENDING") // PENDING | RUNNING | DONE | ERROR

  // Alvo (REVALIDATE aponta pra um EA; MINE não tem eaId ainda)
  eaId        String?
  ea          EA?      @relation(fields: [eaId], references: [id], onDelete: Cascade)

  payloadJson Json?    // parâmetros do job (símbolo, TF, família, etc.)
  resultJson  Json?    // saída do pipeline
  error       String?  @db.Text
  attempts    Int      @default(0)

  // Claim atômico pelo worker
  lockedBy    String?  // id/nome da máquina worker
  lockedAt    DateTime?

  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  @@index([status, type])
  @@index([eaId])
}
