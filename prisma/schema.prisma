generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  clerkId            String    @unique
  email              String    @unique
  name               String?
  subscriptionStatus String    @default("inactive")
  stripeCustomerId   String?   @unique
  stripeSubId        String?   @unique
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  analyses           Analysis[]
  trades             Trade[]
  mt5Accounts        MT5Account[]
}

model Analysis {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode          String
  imageUrl      String?  @db.Text
  status        String
  asset         String?
  timeframe     String?
  resultJson    Json
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId  String?
  signalId    String?   @unique

  asset       String
  timeframe   String?
  mode        String
  direction   String

  entryPrice  Float
  stopPrice   Float
  targetPrice Float?

  exitPrice   Float?
  outcome     String    @default("OPEN")
  pnlAmount   Float?
  rMultiple   Float?

  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?   @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, openedAt])
  @@index([userId, mode, outcome])
}

model MT5Account {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiToken        String       @unique
  label           String?

  // Live account info (atualizado via heartbeat)
  accountNumber   BigInt?
  accountName     String?
  accountServer   String?
  accountCompany  String?
  accountCurrency String?
  leverage        Int?
  balance         Float?
  equity          Float?
  margin          Float?
  freeMargin      Float?
  marginLevel     Float?

  pingMs          Int?
  connectedAt     DateTime?
  lastSeenAt      DateTime?

  createdAt       DateTime     @default(now())

  orders          MT5Order[]
  watchlist       Watchlist[]
  signals         Signal[]
  ticks           MarketTick[]

  @@index([userId])
}

model MT5Order {
  id         String      @id @default(cuid())
  accountId  String
  account    MT5Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol     String
  side       String
  volume     Float       @default(0.01)
  entryType  String      @default("MARKET")
  entryPrice Float?
  stopLoss   Float?
  takeProfit Float?
  comment    String?
  status     String      @default("PENDING")
  mt5Ticket  BigInt?
  errorMsg   String?
  createdAt  DateTime    @default(now())
  pickedAt   DateTime?
  filledAt   DateTime?

  @@index([accountId, status])
  @@index([accountId, createdAt])
}

model Watchlist {
  id          String      @id @default(cuid())
  accountId   String
  account     MT5Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol      String
  timeframe   String      @default("M15")
  mode        String      // "SMC" | "CLASSICO"
  active      Boolean     @default(true)
  lastScanAt  DateTime?
  createdAt   DateTime    @default(now())

  @@unique([accountId, symbol, timeframe, mode])
  @@index([accountId, active])
}

model Signal {
  id                String     @id @default(cuid())
  accountId         String
  account           MT5Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  symbol            String
  timeframe         String
  mode              String

  hasSetup          Boolean    @default(true)
  direction         String?
  probability       Int?
  confidence        String?

  entryPrice        Float?
  entryZoneLow      Float?
  entryZoneHigh     Float?
  stopPrice         Float?
  target1           Float?
  target2           Float?
  target3           Float?
  recommendedTarget Int?
  riskReward        String?

  structure         String?    @db.Text
  justification     String?    @db.Text

  // Tracking
  status            String     @default("PENDING") // PENDING | FILLED | WIN | LOSS | EXPIRED | NO_SETUP
  filledAt          DateTime?
  closedAt          DateTime?
  exitPrice         Float?
  rMultiple         Float?

  // Auto-catalog
  tradeCreated      Boolean    @default(false)

  scannedAt         DateTime   @default(now())
  candleData        Json?

  @@index([accountId, scannedAt])
  @@index([accountId, status])
  @@index([accountId, symbol, timeframe])
}

model MarketTick {
  accountId   String
  account     MT5Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol      String
  bid         Float
  ask         Float
  spread      Float
  updatedAt   DateTime    @default(now())

  @@id([accountId, symbol])
}
