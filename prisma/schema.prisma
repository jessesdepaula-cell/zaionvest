generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  clerkId            String    @unique
  email              String    @unique
  name               String?
  subscriptionStatus String    @default("inactive")
  stripeCustomerId   String?   @unique
  stripeSubId        String?   @unique
  currentPeriodEnd   DateTime?
  geminiApiKey       String?   @db.Text
  openaiApiKey       String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  analyses           Analysis[]
  trades             Trade[]
  watchlist          Watchlist[]
  signals            Signal[]
  ticks              MarketTick[]
  eaDownloads        EADownload[]
  accounts           Account[]
}

model Analysis {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode          String
  imageUrl      String?  @db.Text
  status        String
  asset         String?
  timeframe     String?
  resultJson    Json
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId  String?
  signalId    String?   @unique

  asset       String
  timeframe   String?
  mode        String
  direction   String

  entryPrice  Float
  stopPrice   Float
  targetPrice Float?

  exitPrice   Float?
  outcome     String    @default("OPEN")
  pnlAmount   Float?
  rMultiple   Float?

  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  notes       String?   @db.Text

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, openedAt])
  @@index([userId, mode, outcome])
}

model Watchlist {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol      String
  timeframe   String   @default("M15")
  mode        String   // "SMC" | "CLASSICO"
  active      Boolean  @default(true)
  lastScanAt  DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, symbol, timeframe, mode])
  @@index([userId, active])
}

model Signal {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  symbol            String
  timeframe         String
  mode              String

  hasSetup          Boolean  @default(true)
  direction         String?
  probability       Int?
  confidence        String?

  entryPrice        Float?
  entryZoneLow      Float?
  entryZoneHigh     Float?
  stopPrice         Float?
  target1           Float?
  target2           Float?
  target3           Float?
  recommendedTarget Int?
  riskReward        String?

  structure         String?  @db.Text
  justification     String?  @db.Text

  tipoSetup         String?
  checklistSmc      Json?
  checklistClassico Json?

  status            String   @default("PENDING") // PENDING | FILLED | WIN | LOSS | EXPIRED | NO_SETUP
  filledAt          DateTime?
  closedAt          DateTime?
  exitPrice         Float?
  rMultiple         Float?
  maxTargetHit      Int?     // maior alvo atingido: 1, 2 ou 3 (null = nenhum)

  tradeCreated      Boolean  @default(false)

  scannedAt         DateTime @default(now())
  candleData        Json?

  @@index([userId, scannedAt])
  @@index([userId, status])
  @@index([userId, symbol, timeframe])
}

model MarketTick {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  bid       Float
  ask       Float
  spread    Float
  updatedAt DateTime @default(now())

  @@id([userId, symbol])
}

// ─── EA Marketplace ──────────────────────────────────────────────────────────

model EA {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  symbol          String
  timeframe       String
  style           String   // "trend" | "reversal" | "breakout" | "range"
  exitMode        String   // "reversal" | "fixed_sltp"

  // Métricas WFA (pipeline DQ Labs)
  wfe             Float?
  profitFactor    Float?
  maxDrawdown     Float?
  totalTrades     Int?
  oosWins         Int?
  oosTotalWindows Int?

  // Status de aprovação
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  lastValidatedAt DateTime?

  // Caminho do .ex5 compilado no storage (Modelo A: params baked-in no binário)
  fileUrl         String?  @db.Text

  // Definição INTERNA da estratégia (family, exit_mode e params numéricos).
  // Necessária pro worker re-rodar a revalidação e recompilar. NUNCA é
  // retornada pelo /status público (que só seleciona id/slug/name/status).
  strategyDef     Json?

  // Curva de capital OOS (array de {date, value})
  equityCurveOos  Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  downloads       EADownload[]
  validations     EAValidation[]
  jobs            Job[]

  @@index([status])
  @@index([symbol, timeframe])
}

model EADownload {
  id        String   @id @default(cuid())
  eaId      String
  ea        EA       @relation(fields: [eaId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eaId, userId])
  @@index([userId])
  @@index([eaId])
}

model EAValidation {
  id            String   @id @default(cuid())
  eaId          String
  ea            EA       @relation(fields: [eaId], references: [id], onDelete: Cascade)

  // Resultado consolidado da revalidação
  wfe           Float
  oosWins       Int
  oosTotalWin   Int
  approved      Boolean
  reportMd      String?  @db.Text

  // Janelas individuais da WFA (JSON array)
  windowsJson   Json?

  validatedAt   DateTime @default(now())

  @@index([eaId, validatedAt])
}

// ─── Fila de jobs (consumida pelo worker Windows/MT5) ────────────────────────
// A Vercel só ENFILEIRA (mineração/revalidação). O trabalho pesado — backtest
// no MT5, WFA, Monte Carlo, compilação do .ex5 — roda no worker, que reclama
// jobs PENDING, executa e devolve o resultado.

model Job {
  id          String   @id @default(cuid())
  type        String   // "REVALIDATE" | "MINE"
  status      String   @default("PENDING") // PENDING | RUNNING | DONE | ERROR

  // Alvo (REVALIDATE aponta pra um EA; MINE não tem eaId ainda)
  eaId        String?
  ea          EA?      @relation(fields: [eaId], references: [id], onDelete: Cascade)

  payloadJson Json?    // parâmetros do job (símbolo, TF, família, etc.)
  resultJson  Json?    // saída do pipeline
  error       String?  @db.Text
  attempts    Int      @default(0)

  // Claim atômico pelo worker
  lockedBy    String?  // id/nome da máquina worker
  lockedAt    DateTime?

  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  @@index([status, type])
  @@index([eaId])
}

model Account {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  login           String         @unique
  broker          String?
  server          String?
  currency        String         @default("USD")
  leverage        Int?
  initialBalance  Float?
  initialCapturedAt DateTime?
  totalDeposits   Float?         // soma real de depositos (DEAL_TYPE_BALANCE > 0) enviada pelo EA
  totalWithdrawals Float?        // soma real de saques (DEAL_TYPE_BALANCE < 0), valor positivo
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  snapshots       Snapshot[]
  monitorTrades   MonitorTrade[]
  positions       OpenPosition[]
  robots          RobotMetric[]
  events          MonitorEvent[]

  @@index([userId])
}

model Snapshot {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ts            DateTime @default(now())
  balance       Float
  equity        Float
  margin        Float
  freeMargin    Float
  marginLevel   Float?
  floatingPnL   Float
  openPositions Int
  peakEquity    Float?

  @@index([accountId, ts])
}

model MonitorTrade {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ticket      BigInt   @unique
  symbol      String
  side        String   // BUY | SELL
  volume      Float
  openPrice   Float
  closePrice  Float
  openTime    DateTime
  closeTime   DateTime
  profit      Float
  commission  Float    @default(0)
  swap        Float    @default(0)
  netProfit   Float
  magic       BigInt   @default(0)
  comment     String?

  @@index([accountId, closeTime])
  @@index([accountId, magic])
  @@index([symbol])
}

model OpenPosition {
  id           String   @id @default(cuid())
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ticket       BigInt   @unique
  symbol       String
  side         String
  volume       Float
  openPrice    Float
  currentPrice Float
  sl           Float?
  tp           Float?
  openTime     DateTime
  profit       Float
  swap         Float    @default(0)
  magic        BigInt   @default(0)
  comment      String?
  updatedAt    DateTime @updatedAt

  @@index([accountId])
}

model RobotMetric {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  magic       BigInt
  label       String?
  trades      Int      @default(0)
  wins        Int      @default(0)
  losses      Int      @default(0)
  netProfit   Float    @default(0)
  grossProfit Float    @default(0)
  grossLoss   Float    @default(0)
  lastTradeAt DateTime?
  updatedAt   DateTime @updatedAt

  @@unique([accountId, magic])
}

model MonitorEvent {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  ts        DateTime @default(now())
  kind      String   // ingest | drawdown_alert | reconnect | error
  message   String

  @@index([accountId, ts])
}
