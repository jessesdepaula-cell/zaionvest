# ---------- Clerk ----------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-proj-xxx
OPENAI_MODEL=gpt-4o
# Opcional: overrides por modo de scan
# OPENAI_SCAN_MODEL=gpt-4o
# OPENAI_SCAN_MODEL_SMC=gpt-4o
# OPENAI_SCAN_MODEL_CLASSICO=gpt-4o

# ---------- Pagamento (Asaas) ----------
# Gateway real do produto (R$67/mês). Sem ASAAS_API_KEY em produção, o checkout
# FALHA (não libera assinatura de graça).
ASAAS_API_KEY=
# Segredo do webhook (header asaas-access-token). OBRIGATÓRIO em produção:
# sem ele, POST /api/billing/webhook rejeita (503) — fail-closed contra fraude.
ASAAS_WEBHOOK_SECRET=
# Mock de pagamento SÓ vale fora de produção (NODE_ENV !== "production") E com
# ASAAS_MOCK=true. Em produção é ignorado por segurança.
# ASAAS_MOCK=true

# ---------- Monitor (ingest de contas MT5) ----------
# Opcional (defense-in-depth): se setado, /api/monitor/ingest exige o header
# x-ingest-secret. Ao ligar, atualize também o EA ZaionVest_Monitor.mq5.
# MONITOR_INGEST_SECRET=

# ---------- Narrador de sinais (IA opcional, best-effort) ----------
# O sinal SMC é calculado no código (grátis). O narrador só escreve o texto em PT.
# Se falhar/sem chave, o app usa o texto gerado pelo código (nunca quebra).
# Por padrão reutiliza GEMINI_API_KEY/OPENAI_API_KEY e o mesmo modelo do scan.
# NARRATOR_DISABLED=1              # desliga a narração por IA (usa só template do código)
# NARRATOR_MODEL=gemini-2.0-flash # sobrescreve o modelo (ex: mais barato/sem thinking)
# Provider dedicado (ex: Groq grátis, OpenAI-compatible) sem mexer no scan:
# NARRATOR_API_KEY=gsk_xxx
# NARRATOR_BASE_URL=https://api.groq.com/openai/v1
# NARRATOR_MODEL=llama-3.1-8b-instant

# ---------- Market data ----------
# Twelve Data (forex) — plano Basic gratuito: 800 req/dia, 8 símbolos WS
# https://twelvedata.com/pricing
TWELVEDATA_API_KEY=
# Binance (cripto) — público, sem chave necessária

# ---------- Cron / Scanner 24-7 ----------
# CRON_SECRET protege os endpoints server-to-server (crons + worker MT5) via
# Bearer. OBRIGATÓRIO: sem ele, worker/cron rejeitam (503) — fail-closed.
# Está definido na Vercel.
# O scanner roda 24/7 INDEPENDENTE de aba aberta via pg_cron no Supabase:
#   job "tv-scan-all" (*/10 min) -> net.http_get(scan-all com Bearer CRON_SECRET)
# Gerenciar: select * from cron.job;  |  select cron.unschedule('tv-scan-all');
# O pg_net pode marcar timed_out=true na resposta (não espera os ~26s do scan) —
# é cosmético: o Vercel completa o scan mesmo assim (linhas aparecem no banco).
# O cron diário do vercel.json (0 9 * * *) fica como redundância.
CRON_SECRET=

# ---------- Dono do sistema ----------
# Só este e-mail vê/usa ações destrutivas (ex: "Zerar histórico"). Assinantes não.
# Padrão embutido: jessesdepaula@gmail.com
OWNER_EMAIL=jessesdepaula@gmail.com

# ---------- Database (Prisma + Postgres / Supabase) ----------
DATABASE_URL="postgresql://user:password@localhost:5432/zaionvest"
